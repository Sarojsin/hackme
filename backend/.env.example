# ─── Required: Supabase ──────────────────────────────────
# Get these from your Supabase project dashboard:
#   Settings → API → Project URL / service_role key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Optional: NVIDIA NIM ─────────────────────────────────
# Leave empty to use rule-based classification (no AI needed)
NVIDIA_API_KEY=

# ─── Runtime config ──────────────────────────────────────
# Set to "true" to enable AI-powered responses via NVIDIA NIM (requires NVIDIA_API_KEY)
# Set to "false" to use rule-only mode (no AI dependencies)
USE_LANGGRAPH=true

# Environment mode: "development" or "production"
# In development mode, requests without a Bearer token are accepted
# using "dev-user" as the user ID (for testing via Swagger UI)
APP_ENV=development

# Comma-separated origins allowed by CORS (e.g. http://localhost:5173,https://myapp.com)
# Leave empty to allow all origins (dev default)
CORS_ORIGINS=

# Port the server listens on (default: 8000)
PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO